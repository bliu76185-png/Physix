{
  "version": "3.0",
  "world": {
    "units": { "length": "m", "time": "s", "mass": "kg", "angle": "rad" },
    "bounds": { "min": [-4, -3], "max": [4, 6] },
    "constants": { "g": 9.81 },
    "gravity": { "vector": [0, -9.81] }
  },
  "objects": [
    {
      "id": "particle",
      "label": "粒子",
      "type": "particle",
      "properties": { "mass": 0.4, "radius": 0.15, "restitution": 0.5, "friction": 0.3 },
      "degrees_of_freedom": { "translation": true },
      "geometry": { "type": "circle", "radius": 0.15 },
      "metadata": { "role": "dynamic", "render": { "color": "#1f8a70", "visible": true }, "description": "受时变力场+事件脉冲" }
    },
    {
      "id": "floor",
      "label": "底面",
      "type": "rigid_body",
      "properties": { "mass": 1e10, "inertia": 1e10, "restitution": 0.5, "friction": 0.5 },
      "degrees_of_freedom": { "translation": false, "rotation": false },
      "geometry": { "type": "box", "size": [8, 0.3] },
      "metadata": { "role": "anchor", "fixed": true, "render": { "color": "#6c757d", "visible": true } }
    }
  ],
  "interactions": [
    { "id": "gravity_on_particle", "type": "field", "model": "uniform", "field": "g_field", "applies_to": ["particle"] },
    { "id": "varying_wind", "type": "field", "model": "uniform", "field": "oscillating_wind", "applies_to": ["particle"] },
    {
      "id": "floor_contact",
      "type": "constraint",
      "model": "inequality",
      "between": ["particle", "floor"],
      "parameters": { "condition": "particle.y >= floor.top", "compliance": 0.000001 },
      "metadata": { "priority": 2, "lambda_max": 500 }
    }
  ],
  "fields": [
    {
      "id": "g_field",
      "model": "uniform",
      "vector": [0, -9.81],
      "metadata": { "description": "恒定重力", "render": { "color": "#2f9e44", "pointShape": "circle", "fieldDensity": 0.7, "opacity": 0.45 } }
    },
    {
      "id": "oscillating_wind",
      "model": "uniform",
      "vector": [0, 12],
      "variation": { "temporal": "sin(t*2.5)" },
      "metadata": { "description": "正弦时变垂直力，F=12·sin(2.5t)·m", "render": { "color": "#7048e8", "pointShape": "cross", "fieldDensity": 1.3, "opacity": 0.5 } }
    }
  ],
  "initial_state": {
    "particle": { "position": [-1, 5], "velocity": [1.5, 0] },
    "floor": { "position": [0, -2], "velocity": [0, 0] }
  },
  "events": [
    {
      "id": "side_push",
      "label": "侧向脉冲",
      "trigger": "time",
      "condition": "t >= 2.0",
      "action": {
        "type": "control",
        "target": "particle",
        "controls": [
          { "quantity": "impulse", "operation": "add", "value": [3.5, 0], "duration": 0.15 }
        ]
      },
      "guard": { "retrigger": "never", "max_triggers": 1 },
      "metadata": { "impulseSmoothing": "ramp", "description": "t=2s 时施加 0.15s 平滑水平冲量 3.5 N·s" }
    }
  ],
  "observables": { "position": true, "velocity": true, "acceleration": true, "energy": true, "power": true, "work": true, "events": true },
  "timeline": {
    "terminal_condition": "t >= 6",
    "keyframes": [
      { "t": 0, "state": "initial" },
      { "t": 2.0, "event": "side_push" }
    ]
  }
}

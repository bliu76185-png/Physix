{
  "version": "3.0",
  "world": {
    "units": { "length": "px", "time": "s", "mass": "kg" },
    "scale": 1,
    "bounds": { "min": [0, 0], "max": [820, 560] },
    "constants": {}
  },
  "objects": [
    {
      "id": "cart_a",
      "label": "A车",
      "type": "particle",
      "properties": { "mass": 3, "radius": 34, "material": "sticky", "friction": 0.25 },
      "degrees_of_freedom": { "translation": true },
      "geometry": { "type": "box", "size": [96, 42] },
      "metadata": { "render": { "color": "#2c7be5", "visible": true } }
    },
    {
      "id": "cart_b",
      "label": "B车",
      "type": "particle",
      "properties": { "mass": 3, "radius": 34, "material": "sticky", "friction": 0.25 },
      "degrees_of_freedom": { "translation": true },
      "geometry": { "type": "box", "size": [96, 42] },
      "metadata": { "render": { "color": "#1f8a70", "visible": true } }
    },
    {
      "id": "block_c",
      "label": "C物块",
      "type": "particle",
      "properties": { "mass": 0.8, "material": "rubber", "friction": 0.8 },
      "degrees_of_freedom": { "translation": true },
      "geometry": { "type": "box", "size": [48, 24] },
      "metadata": { "render": { "color": "#d9480f", "visible": true } }
    },
    {
      "id": "floor",
      "label": "水平面",
      "type": "rigid_body",
      "properties": { "mass": 1000000, "inertia": 1000000, "material": "ice", "friction": 0.03 },
      "degrees_of_freedom": { "translation": false, "rotation": false },
      "geometry": { "type": "box", "size": [820, 28] },
      "metadata": { "fixed": true, "render": { "color": "#adb5bd", "visible": true } }
    }
  ],
  "interactions": [
    { "id": "gravity_force", "type": "field", "model": "uniform", "field": "gravity", "applies_to": ["cart_a", "cart_b", "block_c"] },
    { "id": "a_b_contact", "type": "constraint", "model": "inequality", "between": ["cart_a", "cart_b"], "parameters": { "condition": "contact" } },
    { "id": "c_a_contact", "type": "constraint", "model": "inequality", "between": ["block_c", "cart_a"], "parameters": { "condition": "contact" } },
    { "id": "floor_contact_a", "type": "constraint", "model": "inequality", "between": ["cart_a", "floor"], "parameters": { "condition": "contact" } },
    { "id": "floor_contact_b", "type": "constraint", "model": "inequality", "between": ["cart_b", "floor"], "parameters": { "condition": "contact" } }
  ],
  "fields": [
    { "id": "gravity", "model": "uniform", "vector": [0, 980], "metadata": { "render": { "color": "#2f9e44", "pointShape": "circle", "fieldDensity": 0.65, "opacity": 0.42 } } }
  ],
  "initial_state": {
    "cart_a": { "position": [230, 441], "velocity": [230, 0] },
    "cart_b": { "position": [430, 441], "velocity": [0, 0] },
    "block_c": { "position": [230, 408], "velocity": [230, 0] },
    "floor": { "position": [410, 476], "velocity": [0, 0] }
  },
  "events": [],
  "observables": { "position": true, "velocity": true, "energy": true, "constraint_error": true },
  "timeline": { "terminal_condition": "t >= 4.5", "keyframes": [{ "t": 0, "state": "initial" }] }
}

{
  "version": "3.0",
  "world": {
    "units": { "length": "m", "time": "s", "mass": "kg", "angle": "rad" },
    "bounds": { "min": [-3, -2], "max": [3, 2] },
    "constants": {},
    "gravity": { "vector": [0, 0] }
  },
  "objects": [
    {
      "id": "driven_particle",
      "label": "受迫振子",
      "type": "particle",
      "properties": { "mass": 0.3, "radius": 0.12, "friction": 0.3 },
      "degrees_of_freedom": { "translation": true },
      "geometry": { "type": "circle", "radius": 0.12 },
      "metadata": { "role": "dynamic", "render": { "color": "#1f8a70", "visible": true }, "description": "由 motion_profile 表达式 sin(t*2)*1.5 驱动 x 位置" }
    }
  ],
  "interactions": [],
  "fields": [],
  "motion_profiles": [
    {
      "id": "sinusoidal_drive_x",
      "label": "正弦驱动 X",
      "target": "driven_particle",
      "quantity": "position",
      "mode": "set",
      "axis": "x",
      "expression": "sin(t*2)*1.5",
      "time_window": { "start": 0.3, "end": 10 },
      "metadata": { "description": "x(t) = 1.5·sin(2t)，从 t=0.3s 开始" }
    },
    {
      "id": "sinusoidal_drive_y",
      "label": "正弦驱动 Y",
      "target": "driven_particle",
      "quantity": "position",
      "mode": "set",
      "axis": "y",
      "expression": "cos(t*1.3)*0.8",
      "time_window": { "start": 0.3, "end": 10 },
      "metadata": { "description": "y(t) = 0.8·cos(1.3t)" }
    }
  ],
  "initial_state": {
    "driven_particle": { "position": [0, 0.8], "velocity": [0, 0] }
  },
  "events": [],
  "observables": { "position": true, "velocity": true, "acceleration": true, "energy": true, "power": true, "work": true },
  "timeline": { "keyframes": [{ "t": 0, "state": "initial" }], "terminal_condition": "t >= 8" }
}

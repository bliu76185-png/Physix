{
  "version": "3.0",
  "world": {
    "units": { "length": "px", "time": "s", "mass": "kg" },
    "scale": 1,
    "bounds": { "min": [0, 0], "max": [720, 560] },
    "constants": {}
  },
  "objects": [
    { "id": "anchor", "label": "绳端", "type": "particle", "properties": { "mass": 1000000, "radius": 7, "material": "steel" }, "degrees_of_freedom": { "translation": false }, "geometry": { "type": "circle", "radius": 7 }, "metadata": { "fixed": true, "render": { "color": "#555", "visible": true } } },
    { "id": "ball", "label": "撞击小球", "type": "particle", "properties": { "mass": 1, "radius": 18, "material": "rubber" }, "degrees_of_freedom": { "translation": true }, "geometry": { "type": "circle", "radius": 18 }, "metadata": { "render": { "color": "#1f8a70", "visible": true } } },
    { "id": "ground", "label": "地面", "type": "rigid_body", "properties": { "mass": 1000000, "inertia": 1000000, "material": "concrete" }, "degrees_of_freedom": { "translation": false, "rotation": false }, "geometry": { "type": "box", "size": [720, 28] }, "metadata": { "fixed": true, "render": { "color": "#6c757d", "visible": true } } }
  ],
  "interactions": [
    { "id": "rope", "type": "constraint", "model": "distance", "between": ["anchor", "ball"], "parameters": { "value": 190, "compliance": 0 }, "metadata": { "tags": ["rope", "unilateral"], "render": { "color": "#7048e8" } } },
    { "id": "gravity_force", "type": "field", "model": "uniform", "field": "gravity", "applies_to": ["ball"] },
    { "id": "ground_contact", "type": "constraint", "model": "inequality", "between": ["ball", "ground"], "parameters": { "condition": "ball.y <= ground.top" } }
  ],
  "fields": [{ "id": "gravity", "model": "uniform", "vector": [0, 360], "metadata": { "render": { "color": "#2f9e44", "pointShape": "circle", "fieldDensity": 0.65, "opacity": 0.45 } } }],
  "initial_state": {
    "anchor": { "position": [360, 120], "velocity": [0, 0] },
    "ball": { "position": [470, 180], "velocity": [-40, 0] },
    "ground": { "position": [360, 520], "velocity": [0, 0] }
  },
  "events": [],
  "observables": { "position": true, "velocity": true, "energy": true, "constraint_error": true },
  "timeline": { "terminal_condition": "t >= 6", "keyframes": [{ "t": 0, "state": "initial" }] }
}

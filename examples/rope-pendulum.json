{
  "version": "3.0",
  "world": {
    "units": { "length": "m", "time": "s", "mass": "kg" },
    "bounds": { "min": [-3, -3], "max": [3, 4] },
    "constants": { "g": 9.8 },
    "gravity": { "vector": [0, -9.8] }
  },
  "objects": [
    {
      "id": "pivot",
      "label": "悬点",
      "type": "particle",
      "properties": { "mass": 1, "radius": 0.08, "friction": 0.3, "restitution": 0.3 },
      "degrees_of_freedom": { "translation": false, "rotation": false },
      "geometry": { "type": "circle", "radius": 0.1 },
      "metadata": { "role": "anchor", "description": "绳的固定悬挂点", "priority": 1, "lambda_max": 1000 }
    },
    {
      "id": "ball",
      "label": "摆球",
      "type": "particle",
      "properties": { "mass": 1, "radius": 0.2, "friction": 0.3, "restitution": 0.3 },
      "degrees_of_freedom": { "translation": true, "rotation": false },
      "geometry": { "type": "circle", "radius": 0.25 },
      "metadata": { "role": "dynamic", "description": "绳端摆球", "priority": 1, "lambda_max": 1000 }
    }
  ],
  "interactions": [
    {
      "id": "rope_constraint",
      "type": "constraint",
      "model": "distance",
      "between": ["pivot", "ball"],
      "parameters": { "value": 2.0, "compliance": 0 },
      "metadata": {
        "tags": ["rope", "unilateral"],
        "description": "绳约束：只拉不推，球可在绳长范围内自由运动（自由落后）",
        "render": { "color": "#7048e8" }
      }
    },
    {
      "id": "gravity_field",
      "type": "field",
      "model": "uniform",
      "field": "gravity"
    }
  ],
  "fields": [
    {
      "id": "gravity",
      "model": "uniform",
      "vector": [0, -9.8],
      "metadata": { "description": "重力" }
    }
  ],
  "initial_state": {
    "pivot": { "position": [0, 2], "velocity": [0, 0] },
    "ball": { "position": [1.0, 1.5], "velocity": [0, 0] }
  },
  "events": [],
  "observables": { "position": true, "velocity": true, "acceleration": true, "energy": true, "power": true, "work": true },
  "timeline": { "keyframes": [{ "t": 0, "state": "initial" }], "terminal_condition": "t >= 6" }
}

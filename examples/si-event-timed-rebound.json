{
  "version": "3.0",
  "world": {
    "units": { "length": "m", "time": "s", "mass": "kg", "angle": "rad" },
    "bounds": { "min": [-3, -1], "max": [3, 5] },
    "constants": { "g": 9.81 },
    "gravity": { "vector": [0, -9.81] }
  },
  "objects": [
    {
      "id": "ball",
      "label": "小球",
      "type": "particle",
      "properties": { "mass": 0.5, "radius": 0.18, "restitution": 0.4, "friction": 0.3 },
      "degrees_of_freedom": { "translation": true },
      "geometry": { "type": "circle", "radius": 0.18 },
      "metadata": { "role": "dynamic", "render": { "color": "#1f8a70", "visible": true }, "description": "受事件控制的小球" }
    },
    {
      "id": "ground",
      "label": "地面",
      "type": "rigid_body",
      "properties": { "mass": 1e10, "inertia": 1e10, "restitution": 0.4, "friction": 0.5 },
      "degrees_of_freedom": { "translation": false, "rotation": false },
      "geometry": { "type": "box", "size": [6, 0.3] },
      "metadata": { "role": "anchor", "fixed": true, "render": { "color": "#6c757d", "visible": true } }
    }
  ],
  "interactions": [
    { "id": "gravity_on_ball", "type": "field", "model": "uniform", "field": "g_field", "applies_to": ["ball"] },
    {
      "id": "ground_contact",
      "type": "constraint",
      "model": "inequality",
      "between": ["ball", "ground"],
      "parameters": { "condition": "ball.y >= ground.top", "compliance": 0.000001 },
      "metadata": { "priority": 2, "lambda_max": 500 }
    }
  ],
  "fields": [
    {
      "id": "g_field",
      "model": "uniform",
      "vector": [0, -9.81],
      "metadata": { "description": "重力场", "render": { "color": "#2f9e44", "pointShape": "circle", "fieldDensity": 0.8, "opacity": 0.5 } }
    }
  ],
  "initial_state": {
    "ball": { "position": [0, 3.5], "velocity": [0, 0] },
    "ground": { "position": [0, -0.5], "velocity": [0, 0] }
  },
  "events": [
    {
      "id": "timed_push",
      "label": "定时上抛",
      "trigger": "time",
      "condition": "t >= 1.2",
      "action": {
        "type": "control",
        "target": "ball",
        "controls": [
          { "quantity": "velocity", "operation": "set", "value": [1.5, 6], "duration": "persistent" }
        ],
        "inferred_force": {
          "id": "push_force",
          "label": "事件推力（反解）",
          "mode": "counteract_to_hold_velocity"
        }
      },
      "guard": { "retrigger": "never", "max_triggers": 1 },
      "metadata": { "description": "t=1.2s 时触发：设置速度向上向右，模拟外力推动" }
    }
  ],
  "observables": { "position": true, "velocity": true, "acceleration": true, "energy": true, "power": true, "work": true, "events": true },
  "timeline": {
    "terminal_condition": "t >= 5",
    "keyframes": [
      { "t": 0, "state": "initial" },
      { "t": 1.2, "event": "timed_push" }
    ]
  }
}
